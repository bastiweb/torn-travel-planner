<Window x:Class="TornStockTravel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TornStockTravel.Views"
        Title="Torn Stock Travel"
        Width="980"
        Height="720"
        MinWidth="760"
        MinHeight="520"
        Icon="Assets/AppIcon.ico"
        WindowState="Maximized"
        Background="#0B1120">
  <Grid>
    <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <views:StatusHeader x:Name="StatusHeader" Grid.Row="0" />

    <TabControl Grid.Row="1">
      <TabItem Header="Dashboard">
        <Grid Margin="0,14,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,18">
      <Border Style="{StaticResource StatusCardStyle}" Margin="0,0,8,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Status" />
          <TextBlock x:Name="StatusText" Style="{StaticResource ValueTextStyle}" Text="Waiting..." />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatusCardStyle}" Margin="4,0,8,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Last update" />
          <TextBlock x:Name="LastUpdatedText" Style="{StaticResource ValueTextStyle}" Text="-" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatusCardStyle}" Margin="4,0,8,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Next refresh" />
          <TextBlock x:Name="NextRefreshText" Style="{StaticResource ValueTextStyle}" Text="-" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatusCardStyle}" Margin="4,0,0,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Items" />
          <TextBlock x:Name="RecordCountText" Style="{StaticResource ValueTextStyle}" Text="-" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <Border Grid.Row="1"
            Background="#111827"
            BorderBrush="#243044"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#162033" Padding="16">
          <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Right"
                    Background="#1E3A3A"
                    CornerRadius="12"
                    Padding="10,5">
              <TextBlock x:Name="IntervalText"
                         Foreground="#99F6E4"
                         FontSize="12"
                         FontWeight="Bold"
                         Text="Interval: 5 minutes" />
            </Border>
            <StackPanel>
              <TextBlock Text="API response"
                         Foreground="#F8FAFC"
                         FontSize="16"
                         FontWeight="SemiBold" />
              <TextBlock x:Name="EndpointText"
                         Foreground="#94A3B8"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </StackPanel>
          </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="#101827"
                BorderBrush="#243044"
                BorderThickness="0,1,0,1"
                Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Next trip recommendation"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationTitleText"
                         Text="Waiting for dashboard data"
                         Foreground="#F8FAFC"
                         FontSize="18"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RecommendationReasonText"
                         Text="-"
                         Foreground="#94A3B8"
                         FontSize="12"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="18,0,0,0">
              <TextBlock Text="Depart"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationDepartText"
                         Text="-"
                         Foreground="#93C5FD"
                         FontSize="13"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="18,0,0,0">
              <TextBlock Text="Arrive"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationArriveText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="3" Margin="18,0,0,0">
              <TextBlock Text="Profit / h"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationProfitText"
                         Text="-"
                         Foreground="#FDBA74"
                         FontSize="16"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="4" Margin="18,0,0,0">
              <TextBlock Text="Cash / limit"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationCashText"
                         Text="-"
                         Foreground="#A7F3D0"
                         FontSize="14"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RecommendationCashStatusText"
                         Text="-"
                         Foreground="#94A3B8"
                         FontSize="11"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#0F172A"
                BorderBrush="#243044"
                BorderThickness="0,0,0,1"
                Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Travel status"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelDestinationText"
                         Text="Not traveling"
                         Foreground="#F8FAFC"
                         FontSize="18"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="18,0,0,0">
              <TextBlock Text="Time left"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelCountdownText"
                         Text="-"
                         Foreground="#5EEAD4"
                         FontSize="20"
                         FontWeight="Bold" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="18,0,0,0">
              <TextBlock Text="Departed"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelDepartedText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="3" Margin="18,0,0,0">
              <TextBlock Text="Arrival"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelArrivalText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="4" Margin="18,0,0,0">
              <TextBlock Text="Wallet"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="WalletText"
                         Text="-"
                         Foreground="#A7F3D0"
                         FontSize="14"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="VaultText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="11"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="#0B1120"
                BorderBrush="#243044"
                BorderThickness="0,0,0,1"
                Padding="16,12">
          <StackPanel>
            <UniformGrid Columns="4">
              <StackPanel Margin="0,0,12,10">
                <TextBlock Text="Inventory value"
                           Foreground="#64748B"
                           FontSize="10"
                           FontWeight="Bold" />
                <TextBlock x:Name="InventoryValueText"
                           Text="-"
                           Foreground="#A7F3D0"
                           FontSize="16"
                           FontWeight="Bold" />
                <TextBlock x:Name="InventoryDetailsText"
                           Text="-"
                           Foreground="#94A3B8"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Margin="0,0,12,10">
                <TextBlock Text="Expected profit"
                           Foreground="#64748B"
                           FontSize="10"
                           FontWeight="Bold" />
                <TextBlock x:Name="InventoryProfitText"
                           Text="-"
                           Foreground="#FDBA74"
                           FontSize="16"
                           FontWeight="Bold" />
                <TextBlock x:Name="WatchlistSummaryText"
                           Text="-"
                           Foreground="#94A3B8"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Margin="0,0,12,10">
                <TextBlock Text="Forecast quality"
                           Foreground="#64748B"
                           FontSize="10"
                           FontWeight="Bold" />
                <TextBlock x:Name="ForecastQualityBadgeText"
                           Text="-"
                           Foreground="#5EEAD4"
                           FontSize="16"
                           FontWeight="Bold" />
                <TextBlock x:Name="ForecastQualityDetailsText"
                           Text="-"
                           Foreground="#94A3B8"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Watchlist"
                           Foreground="#64748B"
                           FontSize="10"
                           FontWeight="Bold" />
                <DockPanel Margin="0,4,0,0">
                  <Button DockPanel.Dock="Right"
                          MinWidth="64"
                          Height="30"
                          Margin="8,0,0,0"
                          Click="SaveWatchlistButton_Click"
                          Content="Save" />
                  <TextBox x:Name="WatchlistBox"
                           Height="30"
                           Background="#111827"
                           BorderBrush="#334155"
                           BorderThickness="1"
                           Foreground="#F8FAFC"
                           Padding="8,4" />
                </DockPanel>
              </StackPanel>
            </UniformGrid>

            <ItemsControl x:Name="CountrySummaryCards" Margin="0,8,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Width="218"
                          Background="{Binding HeatBrush, Mode=OneWay}"
                          BorderBrush="#334155"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="10"
                          Margin="0,0,10,10"
                          ToolTip="Heatmap color shows the country's best profit per hour. Stronger green means higher opportunity; blue and amber are lower tiers.">
                    <StackPanel>
                      <TextBlock Text="{Binding Title, Mode=OneWay}"
                                 Foreground="#F8FAFC"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="{Binding BestProfitPerHourText, Mode=OneWay}"
                                 Foreground="#FDBA74"
                                 FontSize="15"
                                 FontWeight="Bold"
                                 Margin="0,4,0,0" />
                      <TextBlock Text="{Binding BestItemText, Mode=OneWay}"
                                 Foreground="#CBD5E1"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap" />
                      <TextBlock Foreground="#94A3B8"
                                 FontSize="11"
                                 FontWeight="SemiBold">
                        <Run Text="{Binding ProfitableItemCountText, Mode=OneWay}" />
                        <Run Text=" profitable | Restock " />
                        <Run Text="{Binding NextRestockText, Mode=OneWay}" />
                      </TextBlock>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="WatchlistItemsList">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#111827"
                          BorderBrush="#334155"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="8"
                          Margin="0,0,8,8">
                    <StackPanel>
                      <TextBlock Text="{Binding ItemName, Mode=OneWay}"
                                 Foreground="#F8FAFC"
                                 FontWeight="Bold" />
                      <TextBlock Text="{Binding DestinationText, Mode=OneWay}"
                                 Foreground="#94A3B8"
                                 FontSize="11" />
                      <TextBlock Foreground="#FDBA74"
                                 FontSize="11"
                                 FontWeight="Bold">
                        <Run Text="{Binding ProfitPerHourText, Mode=OneWay}" />
                        <Run Text=" | Stock " />
                        <Run Text="{Binding StockText, Mode=OneWay}" />
                      </TextBlock>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>
    </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Stock Overview">
        <views:StockOverviewView x:Name="StockOverview" />
      </TabItem>

      <TabItem Header="History &amp; Trends">
        <views:HistoryTrendsView x:Name="HistoryTrends" Margin="0,14,0,0" />
      </TabItem>

      <TabItem Header="Travel Planner">
        <Grid Margin="0,14,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0"
                  Background="#111827"
                  BorderBrush="#243044"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="16"
                  Margin="0,0,0,14">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock Text="Travel Planner"
                           Foreground="#F8FAFC"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PlannerBarsText"
                           Text="Energy/nerve unavailable"
                           Margin="0,6,0,0"
                           Foreground="#94A3B8"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PlannerForecastText"
                           Text="Forecast unavailable"
                           Margin="0,4,0,0"
                           Foreground="#CBD5E1"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PlannerWindowSummaryText"
                           Text="Set an active play window to build a session route."
                           Margin="0,4,0,0"
                           Foreground="#5EEAD4"
                           FontSize="12"
                           FontWeight="Bold"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="PlannerWalletReadinessText"
                           Text="Wallet readiness unavailable"
                           Margin="0,4,0,0"
                           Foreground="#A7F3D0"
                           FontSize="12"
                           FontWeight="Bold"
                           TextWrapping="Wrap" />
                <WrapPanel Margin="0,12,0,0">
                  <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="Planner preset"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <ComboBox x:Name="PlannerPresetBox"
                              Width="190"
                              Height="32"
                              Margin="0,6,0,0"
                              DisplayMemberPath="Name" />
                  </StackPanel>
                  <Button MinWidth="78"
                          Height="32"
                          Margin="0,23,8,0"
                          Click="ApplyPlannerPresetButton_Click"
                          Content="Apply" />
                  <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Preset name"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <TextBox x:Name="PlannerPresetNameBox"
                             Width="170"
                             Height="32"
                             Margin="0,6,0,0"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,5" />
                  </StackPanel>
                  <Button MinWidth="92"
                          Height="32"
                          Margin="0,23,0,0"
                          Click="SavePlannerPresetButton_Click"
                          Content="Save preset" />
                </WrapPanel>
                <WrapPanel Margin="0,12,0,0">
                  <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="Target item"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <TextBox x:Name="PlannerTargetItemBox"
                             Width="180"
                             Height="32"
                             Margin="0,6,0,0"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,5"
                             TextChanged="PlannerFilter_Changed" />
                  </StackPanel>

                  <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="Session exclude items"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <TextBox x:Name="PlannerExcludedItemsBox"
                             Width="220"
                             Height="32"
                             Margin="0,6,0,0"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,5"
                             TextChanged="PlannerFilter_Changed" />
                  </StackPanel>

                  <StackPanel MaxWidth="620"
                              Margin="0,0,0,8">
                    <TextBlock Text="Exclude countries"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <WrapPanel x:Name="PlannerExcludedCountryPanel"
                               Margin="0,4,0,0">
                      <CheckBox Content="Mexico" Tag="mex" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Cayman Islands" Tag="cay" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Canada" Tag="can" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Hawaii" Tag="haw" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="United Kingdom" Tag="uni" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Argentina" Tag="arg" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Switzerland" Tag="swi" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Japan" Tag="jap" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="China" Tag="chi" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="UAE" Tag="uae" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="South Africa" Tag="sou" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                    </WrapPanel>
                  </StackPanel>
                </WrapPanel>
              </StackPanel>

              <WrapPanel Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right">
                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Active from"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <TextBox x:Name="PlannerStartTimeBox"
                           Width="70"
                           Height="34"
                           Margin="0,6,0,0"
                           Background="#0B1120"
                           BorderBrush="#334155"
                           BorderThickness="1"
                           Foreground="#F8FAFC"
                           Padding="10,6"
                           LostFocus="PlannerWindow_Changed"
                           KeyDown="PlannerWindowBox_KeyDown" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Active until"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <TextBox x:Name="PlannerEndTimeBox"
                           Width="70"
                           Height="34"
                           Margin="0,6,0,0"
                           Background="#0B1120"
                           BorderBrush="#334155"
                           BorderThickness="1"
                           Foreground="#F8FAFC"
                           Padding="10,6"
                           LostFocus="PlannerWindow_Changed"
                           KeyDown="PlannerWindowBox_KeyDown" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Strategy"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <ComboBox x:Name="PlannerStrategyBox"
                            Width="132"
                            Height="34"
                            Margin="0,6,0,0">
                    <ComboBoxItem Content="Conservative" Tag="Conservative" />
                    <ComboBoxItem Content="Balanced" Tag="Balanced" />
                    <ComboBoxItem Content="Aggressive" Tag="Aggressive" />
                  </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Carry capacity"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <ComboBox x:Name="PlannerCapacityProfileBox"
                            Width="132"
                            Height="34"
                            Margin="0,6,0,0"
                            SelectionChanged="PlannerCapacityProfileBox_SelectionChanged">
                    <ComboBoxItem Content="Settings" Tag="0" />
                    <ComboBoxItem Content="Standard 15" Tag="15" />
                    <ComboBoxItem Content="Suitcase 20" Tag="20" />
                    <ComboBoxItem Content="WLT 29" Tag="29" />
                    <ComboBoxItem Content="Business 34" Tag="34" />
                  </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Capacity"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <TextBox x:Name="PlannerCapacityBox"
                           Width="70"
                           Height="34"
                           Margin="0,6,0,0"
                           Background="#0B1120"
                           BorderBrush="#334155"
                           BorderThickness="1"
                           Foreground="#F8FAFC"
                           Padding="10,6"
                           LostFocus="PlannerWindow_Changed"
                           KeyDown="PlannerWindowBox_KeyDown" />
                </StackPanel>

                <Button MinWidth="94"
                        Height="34"
                        Margin="0,20,0,0"
                        Click="PlannerUseNowButton_Click"
                        Content="Start now" />
              </WrapPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Background="#0F172A"
                  BorderBrush="#243044"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,14">
            <StackPanel>
              <TextBlock Text="Route timeline"
                         Foreground="#94A3B8"
                         FontSize="11"
                         FontWeight="Bold" />
              <ItemsControl x:Name="TravelPlannerTimeline"
                            Margin="0,10,0,0">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Width="236"
                            MinHeight="92"
                            Background="#111827"
                            BorderBrush="#243044"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,10,10">
                      <StackPanel>
                        <TextBlock Text="{Binding Title, Mode=OneWay}"
                                   Foreground="#5EEAD4"
                                   FontSize="11"
