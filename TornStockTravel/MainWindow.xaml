                            Height="34"
                            Margin="10,0,0,0"
                            Click="SaveAlertSettingsButton_Click"
                            Content="Save" />
                    <TextBlock x:Name="AlertSettingsStatusText"
                               VerticalAlignment="Center"
                               Foreground="#5EEAD4"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                  </DockPanel>
                </StackPanel>
              </Border>

