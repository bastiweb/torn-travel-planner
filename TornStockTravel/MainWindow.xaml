                                 Margin="22,4,0,0"
                                 Foreground="#64748B"
                                 FontSize="11"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Margin="12,0,0,12">
                      <TextBlock Text="Lead time in minutes"
