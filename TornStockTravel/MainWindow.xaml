<Window x:Class="TornStockTravel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Torn Stock Travel"
        Width="980"
        Height="720"
        MinWidth="760"
        MinHeight="520"
        Icon="Assets/AppIcon.ico"
        WindowState="Maximized"
        Background="#0B1120">
  <Grid>
    <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
      <Button x:Name="RefreshButton"
              DockPanel.Dock="Right"
              MinWidth="150"
              Height="38"
              Padding="14,0"
              Click="RefreshButton_Click"
              Content="Refresh now" />
      <StackPanel>
        <TextBlock Text="YATA Travel Export"
                   Foreground="#5EEAD4"
                   FontSize="12"
                   FontWeight="Bold" />
        <TextBlock Text="Torn Stock Travel"
                   Foreground="#F8FAFC"
                   FontSize="28"
                   FontWeight="SemiBold" />
      </StackPanel>
    </DockPanel>

    <TabControl Grid.Row="1">
      <TabItem Header="Dashboard">
        <Grid Margin="0,14,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

    <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,18">
      <Border Style="{StaticResource StatusCardStyle}" Margin="0,0,8,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Status" />
          <TextBlock x:Name="StatusText" Style="{StaticResource ValueTextStyle}" Text="Waiting..." />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatusCardStyle}" Margin="4,0,8,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Last update" />
          <TextBlock x:Name="LastUpdatedText" Style="{StaticResource ValueTextStyle}" Text="-" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatusCardStyle}" Margin="4,0,8,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Next refresh" />
          <TextBlock x:Name="NextRefreshText" Style="{StaticResource ValueTextStyle}" Text="-" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatusCardStyle}" Margin="4,0,0,0">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="Items" />
          <TextBlock x:Name="RecordCountText" Style="{StaticResource ValueTextStyle}" Text="-" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <Border Grid.Row="1"
            Background="#111827"
            BorderBrush="#243044"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#162033" Padding="16">
          <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Right"
                    Background="#1E3A3A"
                    CornerRadius="12"
                    Padding="10,5">
              <TextBlock x:Name="IntervalText"
                         Foreground="#99F6E4"
                         FontSize="12"
                         FontWeight="Bold"
                         Text="Interval: 5 minutes" />
            </Border>
            <StackPanel>
              <TextBlock Text="API response"
                         Foreground="#F8FAFC"
                         FontSize="16"
                         FontWeight="SemiBold" />
              <TextBlock x:Name="EndpointText"
                         Foreground="#94A3B8"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </StackPanel>
          </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="#101827"
                BorderBrush="#243044"
                BorderThickness="0,1,0,1"
                Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Next trip recommendation"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationTitleText"
                         Text="Waiting for dashboard data"
                         Foreground="#F8FAFC"
                         FontSize="18"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RecommendationReasonText"
                         Text="-"
                         Foreground="#94A3B8"
                         FontSize="12"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="18,0,0,0">
              <TextBlock Text="Depart"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationDepartText"
                         Text="-"
                         Foreground="#93C5FD"
                         FontSize="13"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="18,0,0,0">
              <TextBlock Text="Arrive"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationArriveText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="3" Margin="18,0,0,0">
              <TextBlock Text="Profit / h"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationProfitText"
                         Text="-"
                         Foreground="#FDBA74"
                         FontSize="16"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="4" Margin="18,0,0,0">
              <TextBlock Text="Cash / limit"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="RecommendationCashText"
                         Text="-"
                         Foreground="#A7F3D0"
                         FontSize="14"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RecommendationCashStatusText"
                         Text="-"
                         Foreground="#94A3B8"
                         FontSize="11"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#0F172A"
                BorderBrush="#243044"
                BorderThickness="0,0,0,1"
                Padding="16,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock Text="Travel status"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelDestinationText"
                         Text="Not traveling"
                         Foreground="#F8FAFC"
                         FontSize="18"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="18,0,0,0">
              <TextBlock Text="Time left"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelCountdownText"
                         Text="-"
                         Foreground="#5EEAD4"
                         FontSize="20"
                         FontWeight="Bold" />
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="18,0,0,0">
              <TextBlock Text="Departed"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelDepartedText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="3" Margin="18,0,0,0">
              <TextBlock Text="Arrival"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="TravelArrivalText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="4" Margin="18,0,0,0">
              <TextBlock Text="Wallet"
                         Foreground="#64748B"
                         FontSize="10"
                         FontWeight="Bold" />
              <TextBlock x:Name="WalletText"
                         Text="-"
                         Foreground="#A7F3D0"
                         FontSize="14"
                         FontWeight="Bold"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="VaultText"
                         Text="-"
                         Foreground="#CBD5E1"
                         FontSize="11"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="#111827"
                BorderBrush="#243044"
                BorderThickness="0,0,0,1"
                Padding="16,12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#94A3B8"
                       FontWeight="SemiBold"
                       Margin="0,0,12,0"
                       Text="Search items" />
            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     Height="34"
                     Background="#0B1120"
                     BorderBrush="#334155"
                     BorderThickness="1"
                     Foreground="#F8FAFC"
                     Padding="10,6"
                     TextChanged="SearchBox_TextChanged" />
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Top"
                       Foreground="#94A3B8"
                       FontWeight="SemiBold"
                       Margin="0,12,12,0"
                       Text="Countries" />
            <WrapPanel Grid.Row="1"
                       Grid.Column="1"
                       x:Name="CountryFilterPanel"
                       Margin="0,8,0,0">
              <CheckBox Content="Mexico" Tag="mex" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="Cayman Islands" Tag="cay" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="Canada" Tag="can" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="Hawaii" Tag="haw" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="United Kingdom" Tag="uni" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="Argentina" Tag="arg" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="Switzerland" Tag="swi" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="Japan" Tag="jap" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="China" Tag="chi" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="United Arab Emirates" Tag="uae" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
              <CheckBox Content="South Africa" Tag="sou" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
            </WrapPanel>
          </Grid>
        </Border>

        <Grid Grid.Row="4" Background="#111827">
              <TextBlock x:Name="EmptyDashboardText"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#94A3B8"
                         FontSize="15"
                         Text="No dashboard data loaded yet." />

              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="DestinationList" Margin="16">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="#263448"
                              BorderThickness="1"
                              CornerRadius="8"
                              Margin="0,0,0,14"
                              Padding="14">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                          <GradientStop Color="#172033" Offset="0" />
                          <GradientStop Color="#101827" Offset="1" />
                        </LinearGradientBrush>
                      </Border.Background>
                        <Grid>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>

                          <DockPanel Grid.Row="0" LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                              <Border Background="#243044" CornerRadius="12" Padding="10,5" Margin="8,0,0,0">
                                <TextBlock Foreground="#CBD5E1" FontSize="12" FontWeight="SemiBold">
                                  <Run Text="{Binding ItemCount, Mode=OneWay}" />
                                  <Run Text=" Items" />
                                </TextBlock>
                              </Border>
                              <Border Background="#123B3A" CornerRadius="12" Padding="10,5" Margin="8,0,0,0">
                                <TextBlock Foreground="#5EEAD4" FontSize="12" FontWeight="SemiBold">
                                  <Run Text="Quantity " />
                                  <Run Text="{Binding TotalQuantity, Mode=OneWay, StringFormat={}{0:N0}}" />
                                </TextBlock>
                              </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                       Foreground="#F8FAFC"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                          </DockPanel>

                          <ItemsControl Grid.Row="1"
                                        ItemsSource="{Binding Items, Mode=OneWay}"
                                        Margin="0,14,0,0">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <WrapPanel />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Border Width="312"
                                        MinHeight="462"
                                        Background="#0F172A"
                                        BorderBrush="#2E405A"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,0,10,10"
                                        Padding="12">
                                  <Grid>
                                    <Grid.RowDefinitions>
                                      <RowDefinition Height="Auto" />
                                      <RowDefinition Height="*" />
                                      <RowDefinition Height="Auto" />
                                      <RowDefinition Height="Auto" />
                                      <RowDefinition Height="Auto" />
                                      <RowDefinition Height="Auto" />
                                      <RowDefinition Height="Auto" />
                                      <RowDefinition Height="Auto" />
                                      <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                      </Grid.ColumnDefinitions>
                                      <Border Width="48"
                                              Height="48"
                                              Background="#111827"
                                              BorderBrush="#263448"
                                              BorderThickness="1"
                                              CornerRadius="6"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Top">
                                        <Image Source="{Binding ImageUrl, Mode=OneWay}"
                                               Stretch="Uniform"
                                               Margin="5" />
                                      </Border>
                                      <TextBlock Grid.Column="1"
                                                 Text="{Binding Name, Mode=OneWay}"
                                                 Foreground="#E5E7EB"
                                                 FontSize="13"
                                                 FontWeight="SemiBold"
                                                 TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid Grid.Row="1" Margin="0,14,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <StackPanel>
                                        <TextBlock Text="Quantity"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding Quantity, Mode=OneWay, StringFormat={}{0:N0}}"
                                                   Foreground="#5EEAD4"
                                                   FontSize="18"
                                                   FontWeight="Bold" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Cost"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                        <TextBlock Text="{Binding Cost, Mode=OneWay, StringFormat={}{0:N0}}"
                                                   Foreground="#F8FAFC"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right" />
                                      </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <StackPanel>
                                        <TextBlock Text="Market Value"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding MarketValueText, Mode=OneWay}"
                                                   Foreground="#CBD5E1"
                                                    FontSize="13"
                                                    FontWeight="SemiBold" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Value Used"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                        <TextBlock Text="{Binding EffectiveValueText, Mode=OneWay}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right" />
                                      </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,12,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <StackPanel>
                                        <TextBlock Text="Bazaar Price"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBox Text="{Binding BazaarPriceText, Mode=OneWay}"
                                                 Tag="{Binding Id, Mode=OneWay}"
                                                 LostFocus="BazaarPriceBox_LostFocus"
                                                 KeyDown="BazaarPriceBox_KeyDown"
                                                 Background="#0B1120"
                                                 BorderBrush="#334155"
                                                 BorderThickness="1"
                                                 Foreground="#F8FAFC"
                                                 Height="28"
                                                 MinWidth="106"
                                                 Padding="8,4" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Profit"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                        <TextBlock Text="{Binding ProfitText, Mode=OneWay}"
                                                   Foreground="#FACC15"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                      </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="4" Margin="0,12,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <StackPanel>
                                        <TextBlock Text="Buy Amount"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding BuyAmountText, Mode=OneWay}"
                                                   Foreground="#5EEAD4"
                                                   FontSize="14"
                                                   FontWeight="Bold" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Unit Profit"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                        <TextBlock Text="{Binding UnitProfitText, Mode=OneWay}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right" />
                                      </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="5" Margin="0,12,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <StackPanel>
                                        <TextBlock Text="Depart by"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding LatestDepartureLocalText, Mode=OneWay}"
                                                   Foreground="#93C5FD"
                                                   FontSize="14"
                                                   FontWeight="Bold" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Cash needed"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                        <TextBlock Text="{Binding CashNeededText, Mode=OneWay}"
                                                   Foreground="#F8FAFC"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                      </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="6" Margin="0,12,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="0" />
                                        <ColumnDefinition Width="*" MinWidth="96" />
                                      </Grid.ColumnDefinitions>
                                      <StackPanel>
                                        <TextBlock Text="Restock"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding RestockEstimateLabelText, Mode=OneWay}"
                                                   Foreground="#C4B5FD"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RestockWindowLabelText, Mode=OneWay}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RestockAvailabilityText, Mode=OneWay}"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="44" />
                                        <TextBlock Text="{Binding StockoutEstimateLabelText, Mode=OneWay}"
                                                   Foreground="#FCA5A5"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1"
                                                  HorizontalAlignment="Stretch"
                                                  Margin="10,0,0,0">
                                        <TextBlock Text="Confidence"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                        <TextBlock Text="{Binding RestockConfidenceLabelText, Mode=OneWay}"
                                                   Foreground="#E9D5FF"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding StockoutConfidenceLabelText, Mode=OneWay}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right"
                                                   TextTrimming="CharacterEllipsis" />
                                      </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="7" Margin="0,12,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <StackPanel>
                                        <TextBlock Text="Profit / h"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding ProfitPerHourText, Mode=OneWay}"
                                                   Foreground="#FDBA74"
                                                   FontSize="14"
                                                   FontWeight="Bold" />
                                      </StackPanel>
                                      <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="Round Trip"
                                                   Foreground="#64748B"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   TextAlignment="Right" />
                                        <TextBlock Text="{Binding FlightDurationText, Mode=OneWay}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Right" />
                                      </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="8" Margin="0,12,0,0">
                                      <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                      </Grid.ColumnDefinitions>
                                      <Border Background="#172033"
                                              BorderBrush="#263448"
                                              BorderThickness="1"
                                              CornerRadius="6"
                                              Padding="8,6"
                                              Margin="0,0,8,0">
                                        <StackPanel>
                                          <TextBlock Text="Owned"
                                                     Foreground="#64748B"
                                                     FontSize="10"
                                                     FontWeight="Bold" />
                                          <TextBlock Text="{Binding OwnedAmount, Mode=OneWay, StringFormat={}{0:N0}}"
                                                     Foreground="#E5E7EB"
                                                     FontSize="14"
                                                     FontWeight="Bold" />
                                        </StackPanel>
                                      </Border>
                                      <Border Grid.Column="1"
                                              Background="#172033"
                                              BorderBrush="#263448"
                                              BorderThickness="1"
                                              CornerRadius="6"
                                              Padding="8,6"
                                              MinWidth="104">
                                        <StackPanel>
                                          <TextBlock Text="Owned Value"
                                                     Foreground="#64748B"
                                                     FontSize="10"
                                                     FontWeight="Bold"
                                                     TextAlignment="Right" />
                                          <TextBlock Text="{Binding OwnedValueText, Mode=OneWay}"
                                                     Foreground="#A7F3D0"
                                                     FontSize="14"
                                                     FontWeight="Bold"
                                                     TextAlignment="Right" />
                                        </StackPanel>
                                      </Border>
                                    </Grid>
                                  </Grid>
                                </Border>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
        </Grid>
      </Grid>
    </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Travel Planner">
        <Grid Margin="0,14,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0"
                  Background="#111827"
                  BorderBrush="#243044"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="16"
                  Margin="0,0,0,14">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock Text="Travel Planner"
                           Foreground="#F8FAFC"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PlannerBarsText"
                           Text="Energy/nerve unavailable"
                           Margin="0,6,0,0"
                           Foreground="#94A3B8"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PlannerForecastText"
                           Text="Forecast unavailable"
                           Margin="0,4,0,0"
                           Foreground="#CBD5E1"
                           FontSize="12"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PlannerWindowSummaryText"
                           Text="Set an active play window to build a session route."
                           Margin="0,4,0,0"
                           Foreground="#5EEAD4"
                           FontSize="12"
                           FontWeight="Bold"
                           TextWrapping="Wrap" />
                <WrapPanel Margin="0,12,0,0">
                  <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="Target item"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <TextBox x:Name="PlannerTargetItemBox"
                             Width="180"
                             Height="32"
                             Margin="0,6,0,0"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,5"
                             TextChanged="PlannerFilter_Changed" />
                  </StackPanel>

                  <StackPanel Margin="0,0,12,8">
                    <TextBlock Text="Exclude items"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <TextBox x:Name="PlannerExcludedItemsBox"
                             Width="220"
                             Height="32"
                             Margin="0,6,0,0"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,5"
                             TextChanged="PlannerFilter_Changed" />
                  </StackPanel>

                  <StackPanel MaxWidth="620"
                              Margin="0,0,0,8">
                    <TextBlock Text="Exclude countries"
                               Foreground="#94A3B8"
                               FontSize="11"
                               FontWeight="Bold" />
                    <WrapPanel x:Name="PlannerExcludedCountryPanel"
                               Margin="0,4,0,0">
                      <CheckBox Content="Mexico" Tag="mex" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Cayman Islands" Tag="cay" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Canada" Tag="can" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Hawaii" Tag="haw" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="United Kingdom" Tag="uni" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Argentina" Tag="arg" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Switzerland" Tag="swi" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="Japan" Tag="jap" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="China" Tag="chi" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="UAE" Tag="uae" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                      <CheckBox Content="South Africa" Tag="sou" Checked="PlannerFilter_Changed" Unchecked="PlannerFilter_Changed" Margin="0,3,10,3" />
                    </WrapPanel>
                  </StackPanel>
                </WrapPanel>
              </StackPanel>

              <WrapPanel Grid.Column="1"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Right">
                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Active from"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <TextBox x:Name="PlannerStartTimeBox"
                           Width="70"
                           Height="34"
                           Margin="0,6,0,0"
                           Background="#0B1120"
                           BorderBrush="#334155"
                           BorderThickness="1"
                           Foreground="#F8FAFC"
                           Padding="10,6"
                           LostFocus="PlannerWindow_Changed"
                           KeyDown="PlannerWindowBox_KeyDown" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Active until"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <TextBox x:Name="PlannerEndTimeBox"
                           Width="70"
                           Height="34"
                           Margin="0,6,0,0"
                           Background="#0B1120"
                           BorderBrush="#334155"
                           BorderThickness="1"
                           Foreground="#F8FAFC"
                           Padding="10,6"
                           LostFocus="PlannerWindow_Changed"
                           KeyDown="PlannerWindowBox_KeyDown" />
                </StackPanel>

                <StackPanel Margin="0,0,12,0">
                  <TextBlock Text="Strategy"
                             Foreground="#94A3B8"
                             FontSize="11"
                             FontWeight="Bold" />
                  <ComboBox x:Name="PlannerStrategyBox"
                            Width="132"
                            Height="34"
                            Margin="0,6,0,0">
                    <ComboBoxItem Content="Conservative" Tag="Conservative" />
                    <ComboBoxItem Content="Balanced" Tag="Balanced" />
                    <ComboBoxItem Content="Aggressive" Tag="Aggressive" />
                  </ComboBox>
                </StackPanel>

                <Button MinWidth="94"
                        Height="34"
                        Margin="0,20,0,0"
                        Click="PlannerUseNowButton_Click"
                        Content="Start now" />
              </WrapPanel>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TravelPlannerCards">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Width="332"
                          MinHeight="392"
                          Background="#111827"
                          BorderBrush="#243044"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="16"
                          Margin="0,0,12,12">
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <StackPanel>
                        <TextBlock Text="{Binding Title, Mode=OneWay}"
                                   Foreground="#5EEAD4"
                                   FontSize="12"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding DestinationText, Mode=OneWay}"
                                   Foreground="#F8FAFC"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding ItemName, Mode=OneWay}"
                                   Foreground="#CBD5E1"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                      </StackPanel>

                      <Border Grid.Row="1"
                              Background="#172033"
                              BorderBrush="#263448"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="10"
                              Margin="0,14,0,0">
                        <StackPanel>
                          <TextBlock Text="{Binding TripType, Mode=OneWay}"
                                     Foreground="#C4B5FD"
                                     FontSize="13"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding TimingSourceText, Mode=OneWay}"
                                     Foreground="#5EEAD4"
                                     FontSize="11"
                                     FontWeight="Bold"
                                     TextWrapping="Wrap"
                                     Margin="0,4,0,0" />
                          <TextBlock Text="{Binding WasteText, Mode=OneWay}"
                                     Foreground="#FACC15"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Margin="0,4,0,0" />
                          <TextBlock Text="{Binding Reason, Mode=OneWay}"
                                     Foreground="#94A3B8"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Margin="0,4,0,0" />
                        </StackPanel>
                      </Border>

                      <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="Depart"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding DepartText, Mode=OneWay}"
                                     Foreground="#93C5FD"
                                     FontSize="14"
                                     FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                          <TextBlock Text="Arrive"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding ArriveText, Mode=OneWay}"
                                     Foreground="#CBD5E1"
                                     FontSize="14"
                                     FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                          <TextBlock Text="Return"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding ReturnText, Mode=OneWay}"
                                     Foreground="#CBD5E1"
                                     FontSize="14"
                                     FontWeight="SemiBold" />
                        </StackPanel>
                      </Grid>

                      <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="Profit / h"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding ProfitPerHourDollarText, Mode=OneWay}"
                                     Foreground="#FDBA74"
                                     FontSize="18"
                                     FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                          <TextBlock Text="Profit"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold"
                                     TextAlignment="Right" />
                          <TextBlock Text="{Binding ProfitDollarText, Mode=OneWay}"
                                     Foreground="#FACC15"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     TextAlignment="Right" />
                        </StackPanel>
                      </Grid>

                      <Grid Grid.Row="4" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="Cash needed"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding CashNeededDollarText, Mode=OneWay}"
                                     Foreground="#A7F3D0"
                                     FontSize="14"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding CashStatusText, Mode=OneWay}"
                                     Foreground="#94A3B8"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                          <TextBlock Text="Buy / Stock"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold"
                                     TextAlignment="Right" />
                          <TextBlock Foreground="#CBD5E1"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     TextAlignment="Right">
                            <Run Text="{Binding BuyAmountText, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding StockText, Mode=OneWay}" />
                          </TextBlock>
                          <TextBlock Text="{Binding TimeAwayText, Mode=OneWay, StringFormat=Away {0}}"
                                     Foreground="#94A3B8"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     TextAlignment="Right" />
                        </StackPanel>
                      </Grid>

                      <StackPanel Grid.Row="5" Margin="0,14,0,0">
                        <TextBlock Text="{Binding RestockText, Mode=OneWay}"
                                   Foreground="#C4B5FD"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding StockoutText, Mode=OneWay}"
                                   Foreground="#FCA5A5"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ConfidenceText, Mode=OneWay}"
                                   Foreground="#CBD5E1"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <TabItem Header="Settings">
        <ScrollViewer Margin="0,14,0,0"
                      VerticalScrollBarVisibility="Auto">
          <Border Background="#111827"
                  BorderBrush="#243044"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="20">
            <StackPanel MaxWidth="760"
                        HorizontalAlignment="Left">
              <TextBlock Text="Settings"
                         Foreground="#F8FAFC"
                         FontSize="20"
                         FontWeight="SemiBold" />
              <TextBlock Text="Connection, refresh, travel capacity, and recommendation behavior."
                         Margin="0,6,0,22"
                         Foreground="#94A3B8"
                         FontSize="13"
                         FontWeight="SemiBold" />

              <TextBlock Text="Torn API Key"
                         Foreground="#94A3B8"
                         FontSize="12"
                         FontWeight="Bold" />
              <Grid Margin="0,8,0,22">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ApiKeyBox"
                             Grid.Column="0"
                             Height="34"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             PasswordChar="*"
                             Padding="10,6" />
                <Button Grid.Column="1"
                        MinWidth="96"
                        Height="34"
                        Margin="10,0,0,0"
                        Click="SaveApiKeyButton_Click"
                        Content="Save" />
                <TextBlock x:Name="ApiKeyStatusText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="#5EEAD4"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="12,0,0,0" />
              </Grid>

              <UniformGrid Columns="2">
                <StackPanel Margin="0,0,12,18">
                  <TextBlock Text="Buy capacity"
                             Foreground="#94A3B8"
                             FontSize="12"
                             FontWeight="Bold" />
                  <DockPanel Margin="0,8,0,0">
                    <Button DockPanel.Dock="Right"
                            MinWidth="80"
                            Height="34"
                            Margin="10,0,0,0"
                            Click="SaveBuyCapacityButton_Click"
                            Content="Save" />
                    <TextBox x:Name="BuyCapacityBox"
                             Height="34"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,6" />
                  </DockPanel>
                </StackPanel>

                <StackPanel Margin="12,0,0,18">
                  <TextBlock Text="Refresh interval"
                             Foreground="#94A3B8"
                             FontSize="12"
                             FontWeight="Bold" />
                  <DockPanel Margin="0,8,0,0">
                    <Button DockPanel.Dock="Right"
                            MinWidth="80"
                            Height="34"
                            Margin="10,0,0,0"
                            Click="SaveRefreshIntervalButton_Click"
                            Content="Save" />
                    <TextBox x:Name="RefreshIntervalBox"
                             Height="34"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,6" />
                  </DockPanel>
                </StackPanel>

                <StackPanel Margin="0,0,12,18">
                  <TextBlock Text="Max spend %"
                             Foreground="#94A3B8"
                             FontSize="12"
                             FontWeight="Bold" />
                  <DockPanel Margin="0,8,0,0">
                    <Button DockPanel.Dock="Right"
                            MinWidth="80"
                            Height="34"
                            Margin="10,0,0,0"
                            Click="SaveMaxSpendPercentButton_Click"
                            Content="Save" />
                    <TextBox x:Name="MaxSpendPercentBox"
                             Height="34"
                             Background="#0B1120"
                             BorderBrush="#334155"
                             BorderThickness="1"
                             Foreground="#F8FAFC"
                             Padding="10,6" />
                  </DockPanel>
                </StackPanel>

                <StackPanel Margin="12,0,0,18">
                  <TextBlock Text="Restock confidence"
                             Foreground="#94A3B8"
                             FontSize="12"
                             FontWeight="Bold" />
                  <ComboBox x:Name="RestockAvailabilityModeBox"
                            Height="34"
                            Margin="0,8,0,0"
                            Background="#0B1120"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            Foreground="#F8FAFC"
                            Padding="8,4">
                    <ComboBoxItem Content="Conservative" Tag="Conservative" />
                    <ComboBoxItem Content="Median" Tag="Median" />
                  </ComboBox>
                </StackPanel>
              </UniformGrid>
            </StackPanel>
          </Border>
        </ScrollViewer>
      </TabItem>
    </TabControl>
    </Grid>

    <Border x:Name="ErrorToast"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            MaxWidth="420"
            Margin="24"
            Padding="14,12"
            Background="#172033"
            BorderBrush="#7F1D1D"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="Collapsed">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="Refresh warning"
                     Foreground="#FCA5A5"
                     FontSize="12"
                     FontWeight="Bold" />
          <TextBlock x:Name="ErrorToastText"
                     Margin="0,4,0,0"
                     Foreground="#CBD5E1"
                     FontSize="12"
                     TextWrapping="Wrap" />
        </StackPanel>
        <Button Grid.Column="1"
                Width="24"
                Height="24"
                Margin="12,0,0,0"
                Padding="0"
                VerticalAlignment="Top"
                Click="DismissErrorToastButton_Click"
                Content="x" />
      </Grid>
    </Border>
  </Grid>
</Window>
