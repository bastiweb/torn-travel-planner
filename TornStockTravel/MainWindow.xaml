                                     Foreground="#5EEAD4"
                                     FontSize="11"
                                     FontWeight="Bold"
                                     TextWrapping="Wrap"
                                     Margin="0,4,0,0" />
                          <TextBlock Text="{Binding WasteText, Mode=OneWay}"
                                     Foreground="#FACC15"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Margin="0,4,0,0" />
                          <TextBlock Text="{Binding Reason, Mode=OneWay}"
                                     Foreground="#94A3B8"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap"
                                     Margin="0,4,0,0" />
                        </StackPanel>
                      </Border>

                      <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="Depart"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding DepartText, Mode=OneWay}"
                                     Foreground="#93C5FD"
                                     FontSize="14"
                                     FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                          <TextBlock Text="Arrive"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding ArriveText, Mode=OneWay}"
                                     Foreground="#CBD5E1"
                                     FontSize="14"
                                     FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                          <TextBlock Text="Return"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding ReturnText, Mode=OneWay}"
                                     Foreground="#CBD5E1"
                                     FontSize="14"
                                     FontWeight="SemiBold" />
                        </StackPanel>
                      </Grid>

                      <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="Profit / h"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding ProfitPerHourDollarText, Mode=OneWay}"
                                     Foreground="#FDBA74"
                                     FontSize="18"
                                     FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                          <TextBlock Text="Profit"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold"
                                     TextAlignment="Right" />
                          <TextBlock Text="{Binding ProfitDollarText, Mode=OneWay}"
                                     Foreground="#FACC15"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     TextAlignment="Right" />
                        </StackPanel>
                      </Grid>

                      <Grid Grid.Row="4" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="Cash needed"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding CashNeededDollarText, Mode=OneWay}"
                                     Foreground="#A7F3D0"
                                     FontSize="14"
                                     FontWeight="Bold" />
                          <TextBlock Text="{Binding CashStatusText, Mode=OneWay}"
                                     Foreground="#94A3B8"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                          <TextBlock Text="Buy / Stock"
                                     Foreground="#64748B"
                                     FontSize="10"
                                     FontWeight="Bold"
                                     TextAlignment="Right" />
                          <TextBlock Foreground="#CBD5E1"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     TextAlignment="Right">
                            <Run Text="{Binding BuyAmountText, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding StockText, Mode=OneWay}" />
                          </TextBlock>
                          <TextBlock Text="{Binding TimeAwayText, Mode=OneWay, StringFormat=Away {0}}"
                                     Foreground="#94A3B8"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     TextAlignment="Right" />
                        </StackPanel>
                      </Grid>

                      <StackPanel Grid.Row="5" Margin="0,14,0,0">
                        <TextBlock Text="{Binding RestockText, Mode=OneWay}"
                                   Foreground="#C4B5FD"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding StockoutText, Mode=OneWay}"
                                   Foreground="#FCA5A5"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ConfidenceText, Mode=OneWay}"
                                   Foreground="#CBD5E1"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PredictionText, Mode=OneWay}"
                                   Foreground="#5EEAD4"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0" />
                        <TextBlock Text="{Binding LocalMedianText, Mode=OneWay}"
                                   Foreground="#94A3B8"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding LatestSafeArrivalText, Mode=OneWay}"
                                   Foreground="#FDBA74"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding StrategyExplanationText, Mode=OneWay}"
                                   Foreground="#A7F3D0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding CooldownText, Mode=OneWay}"
                                   Foreground="#FACC15"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding AlternativeRouteText, Mode=OneWay}"
                                   Foreground="#93C5FD"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                      </StackPanel>

                      <WrapPanel Grid.Row="6"
                                 Margin="0,14,0,0">
                        <Button Height="32"
                                MinWidth="112"
                                Margin="0,0,8,8"
                                Tag="{Binding Candidate, Mode=OneWay}"
                                IsEnabled="{Binding CanMarkBought, Mode=OneWay}"
                                Click="MarkTripBoughtButton_Click"
                                Content="Mark as bought" />
                        <Button Height="32"
                                MinWidth="96"
                                Margin="0,0,8,8"
                                Tag="{Binding Candidate, Mode=OneWay}"
                                IsEnabled="{Binding HasCandidate, Mode=OneWay}"
                                Click="ExcludeTripItemButton_Click"
                                Content="Exclude item" />
                        <Button Height="32"
                                MinWidth="112"
                                Margin="0,0,0,8"
                                Tag="{Binding Candidate, Mode=OneWay}"
                                IsEnabled="{Binding HasCandidate, Mode=OneWay}"
                                Click="ExcludeTripCountryButton_Click"
                                Content="Exclude country" />
                      </WrapPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <TabItem Header="Settings">
        <ScrollViewer Margin="0,14,0,0"
                      VerticalScrollBarVisibility="Auto">
          <Border Background="#111827"
                  BorderBrush="#243044"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="20">
            <StackPanel MaxWidth="760"
                        HorizontalAlignment="Left">
              <TextBlock Text="Settings"
                         Foreground="#F8FAFC"
                         FontSize="20"
                         FontWeight="SemiBold" />
              <TextBlock Text="Connection, refresh, travel capacity, and recommendation behavior."
                         Margin="0,6,0,22"
                         Foreground="#94A3B8"
                         FontSize="13"
                         FontWeight="SemiBold" />

              <Border Background="#0B1120"
                      BorderBrush="#243044"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="14"
                      Margin="0,0,0,22">
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="Updates"
                                 Foreground="#F8FAFC"
                                 FontSize="15"
                                 FontWeight="SemiBold" />
                      <TextBlock Text="Manual update checks and local diagnostic information."
                                 Margin="0,4,0,0"
                                 Foreground="#94A3B8"
                                 FontSize="12"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                    <Button x:Name="CheckForUpdatesButton"
                            Grid.Column="1"
                            MinWidth="132"
                            Height="34"
                            Margin="14,0,0,0"
