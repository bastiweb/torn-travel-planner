                                 Margin="22,4,0,0"
                                 Foreground="#64748B"
                                 FontSize="11"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Margin="12,0,0,12">
                      <CheckBox x:Name="DiscordAlertCheckBox"
                                Content="Send Discord webhook"
                                Foreground="#F8FAFC"
                                FontWeight="SemiBold" />
                      <TextBlock Text="Uses the same alerts as desktop reminders."
                                 Margin="22,4,0,0"
                                 Foreground="#64748B"
                                 FontSize="11"
                                 TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Margin="0,0,12,12">
                      <CheckBox x:Name="LandingReminderCheckBox"
                                Content="Landing reminder"
                                Foreground="#F8FAFC"
                                FontWeight="SemiBold" />
