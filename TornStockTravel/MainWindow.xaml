                             FontSize="12"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />

                  <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,12,12">
                      <CheckBox x:Name="DepartureReminderCheckBox"
