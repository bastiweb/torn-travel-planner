                      <TextBlock Text="Current version"
                                 Foreground="#64748B"
                                 FontSize="11"
                                 FontWeight="Bold" />
                      <TextBlock x:Name="UpdateCurrentVersionText"
                                 Margin="0,3,0,0"
                                 Foreground="#F8FAFC"
                                 FontSize="13"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Margin="12,0,0,12">
                      <TextBlock Text="Latest version"
                                 Foreground="#64748B"
                                 FontSize="11"
                                 FontWeight="Bold" />
                      <TextBlock x:Name="UpdateLatestVersionText"
                                 Margin="0,3,0,0"
                                 Foreground="#F8FAFC"
                                 FontSize="13"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                      <TextBlock Text="Last check"
                                 Foreground="#64748B"
                                 FontSize="11"
                                 FontWeight="Bold" />
                      <TextBlock x:Name="UpdateLastCheckText"
                                 Margin="0,3,0,0"
                                 Foreground="#F8FAFC"
                                 FontSize="13"
                                 FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Margin="12,0,0,0">
                      <TextBlock Text="Status"
                                 Foreground="#64748B"
                                 FontSize="11"
                                 FontWeight="Bold" />
                      <TextBlock x:Name="UpdateStatusText"
                                 Margin="0,3,0,0"
                                 Foreground="#5EEAD4"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </UniformGrid>

                  <TextBlock x:Name="LogPathText"
                             Margin="0,14,0,0"
                             Foreground="#64748B"
                             FontSize="11"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Background="#0B1120"
                      BorderBrush="#243044"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="14"
                      Margin="0,0,0,22">
                <StackPanel>
                  <TextBlock Text="Alerts"
                             Foreground="#F8FAFC"
                             FontSize="15"
                             FontWeight="SemiBold" />
