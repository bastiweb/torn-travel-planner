<UserControl x:Class="TornStockTravel.Views.StatusHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <DockPanel LastChildFill="True" Margin="0,0,0,18">
    <Button x:Name="RefreshButton"
            DockPanel.Dock="Right"
            MinWidth="150"
            Height="38"
            Padding="14,0"
            Click="RefreshButton_Click"
            Content="Refresh now" />
    <StackPanel>
      <TextBlock Text="YATA Travel Export"
                 Foreground="#5EEAD4"
                 FontSize="12"
                 FontWeight="Bold" />
      <TextBlock Text="Torn Stock Travel"
                 Foreground="#F8FAFC"
                 FontSize="28"
                 FontWeight="SemiBold" />
    </StackPanel>
  </DockPanel>
</UserControl>
