<UserControl x:Class="TornStockTravel.Views.ErrorToastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
  <Border HorizontalAlignment="Right"
          VerticalAlignment="Bottom"
          MaxWidth="420"
          Margin="24"
          Padding="14,12"
          Background="#172033"
          BorderBrush="#7F1D1D"
          BorderThickness="1"
          CornerRadius="8">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="Refresh warning"
                   Foreground="#FCA5A5"
                   FontSize="12"
                   FontWeight="Bold" />
        <TextBlock x:Name="ErrorToastText"
                   Margin="0,4,0,0"
                   Foreground="#CBD5E1"
                   FontSize="12"
                   TextWrapping="Wrap" />
      </StackPanel>
      <Button Grid.Column="1"
              Width="24"
              Height="24"
              Margin="12,0,0,0"
              Padding="0"
              VerticalAlignment="Top"
              Click="DismissButton_Click"
              Content="x" />
    </Grid>
  </Border>
</UserControl>
