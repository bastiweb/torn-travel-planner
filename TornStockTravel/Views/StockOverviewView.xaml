<UserControl x:Class="TornStockTravel.Views.StockOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid Margin="0,14,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#111827"
            BorderBrush="#243044"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Margin="0,0,0,14">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   Foreground="#94A3B8"
                   FontWeight="SemiBold"
                   Margin="0,0,12,0"
                   Text="Search items" />
        <TextBox x:Name="SearchBox"
                 Grid.Column="1"
                 Height="34"
                 Background="#0B1120"
                 BorderBrush="#334155"
                 BorderThickness="1"
                 Foreground="#F8FAFC"
                 Padding="10,6"
                 TextChanged="SearchBox_TextChanged" />
        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   VerticalAlignment="Top"
                   Foreground="#94A3B8"
                   FontWeight="SemiBold"
                   Margin="0,12,12,0"
                   Text="Countries" />
        <WrapPanel Grid.Row="1"
                   Grid.Column="1"
                   x:Name="CountryFilterPanel"
                   Margin="0,8,0,0">
          <CheckBox Content="Mexico" Tag="mex" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="Cayman Islands" Tag="cay" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="Canada" Tag="can" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="Hawaii" Tag="haw" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="United Kingdom" Tag="uni" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="Argentina" Tag="arg" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="Switzerland" Tag="swi" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="Japan" Tag="jap" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="China" Tag="chi" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="United Arab Emirates" Tag="uae" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
          <CheckBox Content="South Africa" Tag="sou" Checked="CountryFilter_Changed" Unchecked="CountryFilter_Changed" Margin="0,4,12,4" />
        </WrapPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Background="#111827">
      <TextBlock x:Name="EmptyDashboardText"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Foreground="#94A3B8"
                 FontSize="15"
                 Text="No stock data loaded yet." />

      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="DestinationList" Margin="16">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#263448"
                      BorderThickness="1"
                      CornerRadius="8"
                      Margin="0,0,0,14"
                      Padding="14">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#172033" Offset="0" />
                    <GradientStop Color="#101827" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <DockPanel Grid.Row="0" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                      <Border Background="#243044" CornerRadius="12" Padding="10,5" Margin="8,0,0,0">
                        <TextBlock Foreground="#CBD5E1" FontSize="12" FontWeight="SemiBold">
                          <Run Text="{Binding ItemCount, Mode=OneWay}" />
                          <Run Text=" Items" />
                        </TextBlock>
                      </Border>
                      <Border Background="#123B3A" CornerRadius="12" Padding="10,5" Margin="8,0,0,0">
                        <TextBlock Foreground="#5EEAD4" FontSize="12" FontWeight="SemiBold">
                          <Run Text="Quantity " />
                          <Run Text="{Binding TotalQuantity, Mode=OneWay, StringFormat={}{0:N0}}" />
                        </TextBlock>
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                               Foreground="#F8FAFC"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                  </DockPanel>

                  <ItemsControl Grid.Row="1"
                                ItemsSource="{Binding Items, Mode=OneWay}"
                                Margin="0,14,0,0">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="312"
                                MinHeight="462"
                                Background="#0F172A"
                                BorderBrush="#2E405A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,10,10"
                                Padding="12">
                          <Grid>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="*" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Border Width="48"
                                      Height="48"
                                      Background="#111827"
                                      BorderBrush="#263448"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">
                                <Image Source="{Binding ImageUrl, Mode=OneWay}"
                                       Stretch="Uniform"
                                       Margin="5" />
                              </Border>
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Name, Mode=OneWay}"
                                         Foreground="#E5E7EB"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         TextWrapping="Wrap" />
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,14,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="Quantity"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding Quantity, Mode=OneWay, StringFormat={}{0:N0}}"
                                           Foreground="#5EEAD4"
                                           FontSize="18"
                                           FontWeight="Bold" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Cost"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding Cost, Mode=OneWay, StringFormat={}{0:N0}}"
                                           Foreground="#F8FAFC"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right" />
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,12,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="Market Value"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding MarketValueText, Mode=OneWay}"
                                           Foreground="#CBD5E1"
                                           FontSize="13"
                                           FontWeight="SemiBold" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Value Used"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding EffectiveValueText, Mode=OneWay}"
                                           Foreground="#CBD5E1"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right" />
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,12,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="Bazaar Price"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold" />
                                <TextBox Text="{Binding BazaarPriceText, Mode=OneWay}"
                                         Tag="{Binding Id, Mode=OneWay}"
                                         LostFocus="BazaarPriceBox_LostFocus"
                                         KeyDown="BazaarPriceBox_KeyDown"
                                         Background="#0B1120"
                                         BorderBrush="#334155"
                                         BorderThickness="1"
                                         Foreground="#F8FAFC"
                                         Height="28"
                                         MinWidth="106"
                                         Padding="8,4" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Profit"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding ProfitText, Mode=OneWay}"
                                           Foreground="#FACC15"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,12,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="Buy Amount"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding BuyAmountText, Mode=OneWay}"
                                           Foreground="#5EEAD4"
                                           FontSize="14"
                                           FontWeight="Bold" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Unit Profit"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding UnitProfitText, Mode=OneWay}"
                                           Foreground="#CBD5E1"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right" />
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="5" Margin="0,12,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="Depart by"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding LatestDepartureLocalText, Mode=OneWay}"
                                           Foreground="#93C5FD"
                                           FontSize="14"
                                           FontWeight="Bold" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Cash needed"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding CashNeededText, Mode=OneWay}"
                                           Foreground="#F8FAFC"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="6" Margin="0,12,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="0" />
                                <ColumnDefinition Width="*" MinWidth="96" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="Restock"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding RestockEstimateLabelText, Mode=OneWay}"
                                           Foreground="#C4B5FD"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding RestockWindowLabelText, Mode=OneWay}"
                                           Foreground="#CBD5E1"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding RestockAvailabilityText, Mode=OneWay}"
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           MaxHeight="44" />
                                <TextBlock Text="{Binding StockoutEstimateLabelText, Mode=OneWay}"
                                           Foreground="#FCA5A5"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                              <StackPanel Grid.Column="1"
                                          HorizontalAlignment="Stretch"
                                          Margin="10,0,0,0">
                                <TextBlock Text="Confidence"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding RestockConfidenceLabelText, Mode=OneWay}"
                                           Foreground="#E9D5FF"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding StockoutConfidenceLabelText, Mode=OneWay}"
                                           Foreground="#CBD5E1"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right"
                                           TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="7" Margin="0,12,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <StackPanel>
                                <TextBlock Text="Profit / h"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding ProfitPerHourText, Mode=OneWay}"
                                           Foreground="#FDBA74"
                                           FontSize="14"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding TrendSummaryText, Mode=OneWay}"
                                           ToolTip="{Binding TrendDetailsText, Mode=OneWay}"
                                           Foreground="#A7F3D0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Round Trip"
                                           Foreground="#64748B"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           TextAlignment="Right" />
                                <TextBlock Text="{Binding FlightDurationText, Mode=OneWay}"
                                           Foreground="#CBD5E1"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextAlignment="Right" />
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="8" Margin="0,12,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>
                              <Border Background="#172033"
                                      BorderBrush="#263448"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="8,6"
                                      Margin="0,0,8,0">
                                <StackPanel>
                                  <TextBlock Text="Owned"
                                             Foreground="#64748B"
                                             FontSize="10"
                                             FontWeight="Bold" />
                                  <TextBlock Text="{Binding OwnedAmount, Mode=OneWay, StringFormat={}{0:N0}}"
                                             Foreground="#E5E7EB"
                                             FontSize="14"
                                             FontWeight="Bold" />
                                </StackPanel>
                              </Border>
                              <Border Grid.Column="1"
                                      Background="#172033"
                                      BorderBrush="#263448"
                                      BorderThickness="1"
                                      CornerRadius="6"
                                      Padding="8,6"
                                      MinWidth="104">
                                <StackPanel>
                                  <TextBlock Text="Owned Value"
                                             Foreground="#64748B"
                                             FontSize="10"
                                             FontWeight="Bold"
                                             TextAlignment="Right" />
                                  <TextBlock Text="{Binding OwnedValueText, Mode=OneWay}"
                                             Foreground="#A7F3D0"
                                             FontSize="14"
                                             FontWeight="Bold"
                                             TextAlignment="Right" />
                                </StackPanel>
                              </Border>
                            </Grid>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
